[Unit]
Description=KV260 sigverify daemon
After=systemd-modules-load.service

[Service]
Type=simple
ExecStartPre=/usr/bin/kv260_sigv_pl_clock_init.py --quiet
ExecStart=/usr/bin/kv260_sigv_daemon serve --socket-path /run/kv260-sigv.sock
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
